{
  "name": "@peter.naydenov/walk",
  "description": "Deep copy with fine control during the process. Can be used also as a deep forEach function",
  "version": "5.0.6",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "./src/main.js",
  "type": "module",
  "types": "./types/main.d.ts",
  "exports": {
    ".": {
      "import": "./src/main.js",
      "require": "./dist/walk.cjs",
      "default": "./src/main.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "test": "vitest run",
    "cover": "vitest run --coverage",
    "build": "rollup -c",
    "postbuild": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterNaydenov/walk.git"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "rollup": "^4.62.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "browserslist": "> 2%, not dead",
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
